# ==============================================================================
# LEAD ENRICHMENT SYSTEM - Environment Template (.env.example)
# ==============================================================================
# Copy this file to a new file named '.env' in this directory and fill in values.
# Do not commit the completed '.env' file to Git/GitHub!
# ==============================================================================

# ------------------------------------------------------------------------------
# 🔑 API Keys
# ------------------------------------------------------------------------------
# [REQUIRED] Primary Google Gemini AI Key
# Used by LLM router and JSON clean engines to categorize titles, parse addresses, 
# and map company financials.
GEMINI_API_KEY=your_gemini_api_key_here

# [OPTIONAL] Google Search API Key via SerpAPI
# If set, allows search agents to query Google to discover websites, email addresses, 
# and company facts. If empty, falls back to free JustDial scraping.
SERPAPI_KEY=your_serpapi_key_here

# [OPTIONAL] Apollo.io API Key
# If set, queries Apollo database endpoints to enrich contacts with emails and job titles.
APOLLO_API_KEY=your_apollo_key_here

# [OPTIONAL] Hunter.io API Key
# If set, verifies email addresses for validity (reduces bounce rates).
HUNTER_API_KEY=your_hunter_key_here

# ------------------------------------------------------------------------------
# 🏢 AWS Configuration (S3 & DynamoDB Storage)
# ------------------------------------------------------------------------------
# [REQUIRED] AWS Access Credentials
# Grants your local pipeline script access to read/write raw CSV chunks and cache states.
AWS_ACCESS_KEY_ID=your_aws_access_key_id
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key
AWS_DEFAULT_REGION=us-east-1

# [REQUIRED] S3 Buckets
# AWS_S3_RAW_BUCKET_NAME: Bucket containing raw incoming CSV leads under the raw/ prefix.
# LEADS_MAPPING_BUCKET: Bucket used to upload and download compiled JSON mappings (person_map.json, org_map.json)
AWS_S3_RAW_BUCKET_NAME=raw-data-leads
LEADS_MAPPING_BUCKET=leads-mapping

# [REQUIRED] DynamoDB Tables
# AWS_DYNAMODB_TABLE_NAME: Table used to store clean, validated lead records.
# AWS_DYNAMODB_RAW_TABLE_NAME: Table used to store raw unprocessed search results.
AWS_DYNAMODB_TABLE_NAME=cleaned_data_leads
AWS_DYNAMODB_RAW_TABLE_NAME=raw_data_leads

# ------------------------------------------------------------------------------
# ⚙️ Pipeline Configuration (Optional / Overrides)
# ------------------------------------------------------------------------------
# TARGET_CITIES: Comma-separated list of target cities to filter search locations.
# TARGET_DOMAINS: Comma-separated list of target industries to filter search domains.
TARGET_CITIES=New Delhi,Gurgaon,Noida
TARGET_DOMAINS=real_estate,salon_spa,financial_services,educational_institutes

# Concurrency thread limit for the LLM router agent. Unset or 0 = auto-scaled
PIPELINE_CONCURRENCY=0

# Clean shutdown threshold (in seconds) for pipeline run timeouts. Default: 3000 (50 mins)
MAX_RUN_SECONDS=3000

# S3 file discovery lookup frequency ('hourly', 'daily', etc.)
PIPELINE_FILE_DISCOVERY=hourly

# Maximum new leads to process during a single run loop (useful for testing budget)
MAX_NEW_LEADS=50

# ------------------------------------------------------------------------------
# 📂 Local Storage / IO Paths
# ------------------------------------------------------------------------------
# GEN_INPUT_DIR: Folder where incoming target lead sheets are stored locally.
# GEN_OUTPUT_DIR: Folder where processed run outputs are written locally.
GEN_INPUT_DIR=lead_gen/input
GEN_OUTPUT_DIR=lead_gen/output

# Optional: Path where pipeline local cache/state database is saved
# PIPELINE_DATA_DIR=E:\path\to\pipeline_data

# Optional: Local directory containing raw CSVs to process, bypassing S3 entirely (testing only)
# PIPELINE_LOCAL_RAW_DIR=E:\path\to\test_csvs

# Optional: API security access key for uvicorn/persona FastAPI endpoints (empty = open access)
# API_KEY=your_optional_fastapi_security_header_key
