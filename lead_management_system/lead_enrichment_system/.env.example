# ==============================================================================
# LEAD ENRICHMENT SYSTEM - Environment Template (.env.example)
# ==============================================================================
# Copy this file to '.env' in THIS directory and fill in the values.
# The completed '.env' is git-ignored - never commit real credentials.
#
# Only the variables in SECTION A are read by this system's code
# (clean_orchestrator.py, smart_llm_router.py, persona_api.py, mapping).
# SECTION B is optional and only matters if you also run the sibling
# ../scrape_and_validate_kit, which uses THIS file as its credential fallback.
# ==============================================================================


# ==============================================================================
#  SECTION A - used by the Lead Enrichment System
# ==============================================================================

# ---- Google AI ----------------------------------------------------------------
# [REQUIRED] AI Studio API key. Used by every model in configs/model_limits.json
# whose "vertex" flag is false. (Vertex-flagged models authenticate instead via
# lead_clean/configs/research_lab_service_key.json - never commit that file.)
GEMINI_API_KEY=your_gemini_api_key_here

# ---- AWS credentials ----------------------------------------------------------
# [REQUIRED] IAM keys with S3 + DynamoDB access.
AWS_ACCESS_KEY_ID=your_aws_access_key_id
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key
AWS_DEFAULT_REGION=us-east-1

# ---- AWS resources ------------------------------------------------------------
# [REQUIRED] S3 bucket holding raw/ input CSVs and state/ backups.
AWS_S3_RAW_BUCKET_NAME=raw-data-leads
# [REQUIRED] DynamoDB table names (created by scripts/aws_setup.py).
AWS_DYNAMODB_TABLE_NAME=cleaned_data_leads
AWS_DYNAMODB_RAW_TABLE_NAME=raw_data_leads
# [OPTIONAL] Only needed for the people<->org mapping (build_mapping.py / mapping_ui.py).
# Bucket with people/ + organization/ CSV chunks and the mapping/ outputs.
LEADS_MAPPING_BUCKET=leads-mapping

# ---- Vertex AI (optional) -----------------------------------------------------
# Only needed if configs/model_limits.json enables any "vertex": true model.
# GCP project id + region for the Vertex client (auth via research_lab_service_key.json).
# Leave VERTEX_PROJECT empty to skip Vertex entirely and use only AI-Studio models.
# VERTEX_PROJECT=your_gcp_project_id
# VERTEX_LOCATION=us-central1

# ---- Pipeline runtime knobs (all optional) -----------------------------------
# Cap newly-enriched leads per run (testing / cost control). Unset = no cap.
MAX_NEW_LEADS=50
# Soft time budget in seconds - the run stops cleanly before this elapses.
MAX_RUN_SECONDS=3000
# Parallel enrichment workers. 0 or unset = auto (3 x active models, capped 30).
PIPELINE_CONCURRENCY=0
# S3 file discovery: 'hourly' (list every run) or 'daily' (list once/day, cached).
PIPELINE_FILE_DISCOVERY=hourly
# Where local state/cache lives. Default: <this dir>/pipeline_data
# PIPELINE_DATA_DIR=E:\path\to\pipeline_data
# Process CSVs from a local folder instead of S3 (testing only).
# PIPELINE_LOCAL_RAW_DIR=E:\path\to\test_csvs

# ---- API security (optional) --------------------------------------------------
# If set, every /api/* request must send it as the X-API-Key header.
# Unset = open access (local development).
# API_KEY=your_optional_fastapi_security_header_key
# Alternate .env path for cloud deployments (rarely needed locally).
# ENV_PATH=/path/to/.env


# ==============================================================================
#  SECTION B - shared fallback for ../scrape_and_validate_kit (OPTIONAL)
# ==============================================================================
# This system does NOT read anything below. It lives here only because the
# scrape_and_validate_kit reads this .env as a fallback, so you can keep one
# credential file for both projects. If you don't run that kit, ignore this.
# See ../scrape_and_validate_kit/.env.example for the full, documented list.
#
# GEMINI_MODELS=gemma-4-31b-it,gemini-3.1-flash-lite
# SERPAPI_KEY=your_serpapi_key_here
# APOLLO_API_KEY=your_apollo_key_here
# HUNTER_API_KEY=your_hunter_key_here
# TARGET_DOMAINS=real_estate,salon_spa,financial_services,educational_institutes
# TARGET_CITIES=Delhi,Gurgaon,Noida
# TARGET_LEADS_PER_RUN=10
# PHONE_REGION=IN
