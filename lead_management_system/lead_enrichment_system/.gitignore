*test*.py

# Hide user data
input/
*.csv

# Runtime pipeline state (registry, model state, CSV cache, telemetry)
pipeline_data/

# Generated mapping maps (rebuilt by scripts/build_mapping.py)
lead_clean/mapping_data/
