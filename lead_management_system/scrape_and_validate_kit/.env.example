# ==============================================================================
# SCRAPE & VALIDATION KIT - Environment Template (.env.example)
# ==============================================================================
# Copy this file to a new file named '.env' in this directory and fill in values.
# Do not commit the completed '.env' file to Git/GitHub!
#
# 💡 FALLBACK MECHANISM:
# Any variable NOT explicitly set in this file will automatically fallback and be
# read from '../lead_enrichment_system/.env' if they share the workspace.
# Only uncomment/define a variable here if you wish to override that fallback.
# ==============================================================================

# ------------------------------------------------------------------------------
# 🔑 API Keys (Optional overrides)
# ------------------------------------------------------------------------------
# Primary Google Gemini AI key (drives lead_gen search and lead_val classification)
# GEMINI_API_KEY=your_gemini_api_key_here

# Rotational models to use for LLM tasks (supports list rotation for free limits)
# GEMINI_MODELS=gemma-4-31b-it,gemini-3.1-flash-lite
# GEMINI_RPM=15

# Google Search API key via SerpAPI (optional; falls back to free JustDial scraping if empty)
# SERPAPI_KEY=your_serpapi_key_here

# Apollo API key for lead enrichment details (optional)
# APOLLO_API_KEY=your_apollo_key_here

# Email verification key via Hunter.io (optional)
# HUNTER_API_KEY=your_hunter_key_here

# ------------------------------------------------------------------------------
# ⚙️ Search / Scraping Parameters (lead_gen only)
# ------------------------------------------------------------------------------
# TARGET_DOMAINS: Comma-separated list of target industries matching config/domains.json
# TARGET_CITIES: Comma-separated list of target cities to search.
# TARGET_LEADS_PER_RUN: Max new leads to scrape per execution run.
# TARGET_REGION_SUFFIX: Biases the search results to a specific region/territory.
TARGET_DOMAINS=real_estate,salon_spa,financial_services,educational_institutes
TARGET_CITIES=Delhi,Gurgaon,Noida
TARGET_LEADS_PER_RUN=10
TARGET_REGION_SUFFIX=Delhi NCR

# LangGraph recursion guard for the scraping pipeline (limits execution depth)
GRAPH_RECURSION_LIMIT=300

# Set to 1 to enable Playwright-based browser scraping, 0 to disable
PLAYWRIGHT_ENABLED=1

# ------------------------------------------------------------------------------
# 📞 Contact Formatting & Validation (lead_val only)
# ------------------------------------------------------------------------------
# PHONE_REGION: ISO-2 character country code (used by phonenumbers parser fallback)
# PHONE_COUNTRY_CODE: Prefix country code appended to phone strings if missing
PHONE_REGION=IN
PHONE_COUNTRY_CODE=+91

# ------------------------------------------------------------------------------
# 📂 Local Storage / IO Paths
# ------------------------------------------------------------------------------
# GEN_OUTPUT_DIR: Folder where scraped CSVs, history.json, and search states are saved.
GEN_OUTPUT_DIR=lead_gen/output

# VALIDATION_INPUT_DIR: Folder containing raw CSV sheets to validate.
# VALIDATION_OUTPUT_DIR: Folder where validated lead sheets are written.
# VALIDATION_SAVE_EVERY: Save output CSV incrementally after processing N rows.
VALIDATION_INPUT_DIR=lead_val/input
VALIDATION_OUTPUT_DIR=lead_val/output
VALIDATION_SAVE_EVERY=25
